# Backend service environment
# Copy to config/backend.env before first run:
#   copy config\backend.env.example config\backend.env
#
# Note: DATABASE_URL is intentionally managed in docker-compose-build.yaml
# (environment: block) to enforce the Docker service name "postgres".
# Do NOT set DATABASE_URL here — it will be silently overridden by compose.

# Backend listen address and internal port (inside container)
CONFIG_MAN_HOST=0.0.0.0
CONFIG_MAN_PORT=3000

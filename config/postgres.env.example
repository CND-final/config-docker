# PostgreSQL service environment
# Copy to config/postgres.env before first run:
#   copy config\postgres.env.example config\postgres.env

POSTGRES_DB=config_man
POSTGRES_USER=config_man
POSTGRES_PASSWORD=config_man

# POSTGRES_PORT controls the host-side port mapping in docker-compose-build.yaml.
# Change here AND in the ports: section (or override via shell env) if 5432 is taken.
POSTGRES_PORT=5432

# Root .env.example — template for Docker Compose full-stack mode
#
# Copy this file to .env before running `make docker-up`:
#   cp .env.example .env
#
# Note: backend/.env is a separate file used by `make dev` (local Go run).
# The critical difference from backend/.env:
#   DATABASE_URL here uses "postgres" (Docker service name), not "localhost".

# PostgreSQL
POSTGRES_DB=config_man
POSTGRES_USER=config_man
POSTGRES_PASSWORD=config_man
POSTGRES_PORT=5432

# Backend
# DATABASE_URL must use the Docker service name "postgres", not "localhost"
DATABASE_URL=postgres://config_man:config_man@postgres:5432/config_man?sslmode=disable
CONFIG_MAN_HOST=0.0.0.0
CONFIG_MAN_PORT=3000

# Host port mappings
BACKEND_PORT=3000
FRONTEND_PORT=80
